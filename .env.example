# Local backend settings
SPRING_PROFILES_ACTIVE=local
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/postgres
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=replace-with-a-strong-secret-at-least-256-bits

# AWS S3
S3_BUCKET=equity-committee-voting-images-dev
S3_REGION=eu-north-1
S3_ENDPOINT=
AWS_ACCESS_KEY=replace-with-access-key
AWS_SECRET_KEY=replace-with-secret-key
S3_PRESIGNED_URL_MINUTES=15

# Firebase Cloud Messaging
FCM_ENABLED=false
FCM_SERVICE_ACCOUNT_PATH=

# Local MinIO alternative
# S3_ENDPOINT=http://localhost:9000
# AWS_ACCESS_KEY=minioadmin
# AWS_SECRET_KEY=minioadmin
